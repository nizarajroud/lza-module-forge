# Environment Configuration Template
# Copy this to .env and fill in your values (never commit .env)

# GitHub — target repository for generated Terraform code
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=your-aft-account-customizations-repo

# Bedrock Knowledge Base
KNOWLEDGE_BASE_ID=your_kb_id_here

# Bedrock Model (Claude Sonnet 4.5 via US inference profile)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# AWS Region
AWS_REGION=ca-central-1
