                <mxCell id="ct" value="&lt;b&gt;Module Comparison: Manual vs LZA-Generated&lt;/b&gt;&lt;br&gt;terraform-aws-bedrock-guardrail (manual) vs terraform-aws-bedrock-guardrail-lza (generated)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacing=6;" vertex="1" parent="1">
