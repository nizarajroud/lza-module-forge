                </mxCell>
                <mxCell id="m_resources" value="&lt;b&gt;Resources&lt;/b&gt;&lt;br&gt;• aws_bedrock_guardrail.this&lt;br&gt;• aws_bedrock_guardrail_version.this&lt;br&gt;&lt;br&gt;(2 resources total — pure module)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacing=4;" vertex="1" parent="manual_box">
                    <mxGeometry x="250" y="35" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="m_features" value="&lt;b&gt;Features&lt;/b&gt;&lt;br&gt;• Content filters (6 types)&lt;br&gt;• PII entities (configurable)&lt;br&gt;• Denied topics&lt;br&gt;• Word filters + managed lists&lt;br&gt;• KMS encryption (optional)&lt;br&gt;• Validation blocks on inputs&lt;br&gt;• No provider block inside module" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacing=4;" vertex="1" parent="manual_box">
                    <mxGeometry x="10" y="170" width="220" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="m_absent" value="&lt;b&gt;NOT included&lt;/b&gt;&lt;br&gt;• No LZA tags in module&lt;br&gt;• No CloudWatch alarms&lt;br&gt;• No S3 logging bucket&lt;br&gt;• No IAM roles/policies&lt;br&gt;• No data sources (pure module)&lt;br&gt;• Consumer manages provider+tags" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacing=4;fontColor=#DD344C;" vertex="1" parent="manual_box">
                    <mxGeometry x="250" y="170" width="220" height="140" as="geometry"/>
                </mxCell>
