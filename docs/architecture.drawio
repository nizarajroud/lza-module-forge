                </mxCell>
                <mxCell id="g_lza" value="&lt;b&gt;LZA-Specific (from KB)&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#01A88D&quot;&gt;✓ Tags: clientName=Alithya, CSNA, CostCenter&lt;br&gt;✓ Region: ca-central-1 (hardcoded)&lt;br&gt;✓ KMS: data.aws_kms_key (existing LZA key)&lt;br&gt;✓ Naming: alithya-bedrock-guardrail&lt;br&gt;✓ PII: CA_SOCIAL_INSURANCE_NUMBER&lt;br&gt;✓ Topics: financial/medical/legal advice&lt;br&gt;✓ S3 logs: encryption + HTTPS enforced&lt;br&gt;✓ CloudWatch alarms (blocks + errors)&lt;br&gt;✓ IAM: least-privilege + condition keys&lt;br&gt;✓ Data sources: Endpoint VPC, KMS key&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacing=4;" vertex="1" parent="gen_box">
