                </mxCell>
                <mxCell id="m_files" value="&lt;b&gt;Files&lt;/b&gt;&lt;br&gt;• main.tf (guardrail + version)&lt;br&gt;• variables.tf (12 vars, validations)&lt;br&gt;• outputs.tf (5 outputs)&lt;br&gt;• versions.tf (&gt;= 5.60.0)&lt;br&gt;• README.md&lt;br&gt;• examples/complete/main.tf&lt;br&gt;• tests/" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacing=4;" vertex="1" parent="manual_box">
