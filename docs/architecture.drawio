                <mxCell id="g_resources" value="&lt;b&gt;Resources (9+)&lt;/b&gt;&lt;br&gt;• aws_bedrock_guardrail.main&lt;br&gt;• aws_bedrock_guardrail_version&lt;br&gt;• aws_cloudwatch_log_group&lt;br&gt;• aws_cloudwatch_metric_alarm ×2&lt;br&gt;• aws_iam_role (logging)&lt;br&gt;• aws_iam_role_policy (logging)&lt;br&gt;• aws_iam_policy (usage)&lt;br&gt;• module s3-bucket (logs)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacing=4;" vertex="1" parent="gen_box">
