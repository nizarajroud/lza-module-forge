                </mxCell>
                <mxCell id="g_files" value="&lt;b&gt;Files&lt;/b&gt;&lt;br&gt;• main.tf (all-in-one: resources + vars + outputs)&lt;br&gt;• README.md (28KB — full docs)&lt;br&gt;• examples/complete/ (dir created)&lt;br&gt;• tests/ (dir created)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacing=4;" vertex="1" parent="gen_box">
