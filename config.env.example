# =============================================================================
# LZA Module Forge — Configuration
# =============================================================================
# Copy this file to config.env and fill in your values.
# This file is sourced by scripts and read by the Lambda (local mode).
# NEVER commit config.env — only config.env.example is tracked.
# =============================================================================

# ─── Output Mode ────────────────────────────────────────────────────────────
# "local" = write generated modules to filesystem (for review before commit)
# "github" = commit directly to a GitHub repo via API (original behavior)
OUTPUT_MODE=local

# ─── Local Output (when OUTPUT_MODE=local) ──────────────────────────────────
# Absolute path to the target modules directory
OUTPUT_MODULES_DIR=/home/nizar/HomeWspce/poc-bnc-terraform-modules/modules

# ─── GitHub Output (when OUTPUT_MODE=github) ────────────────────────────────
# Only needed if OUTPUT_MODE=github
GITHUB_TOKEN=
GITHUB_REPO_OWNER=nizarajroud
GITHUB_REPO_NAME=poc-bnc-terraform-modules

# ─── AWS / Bedrock ──────────────────────────────────────────────────────────
AWS_REGION=ca-central-1
AWS_PROFILE=csna-operations-sso-828
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
KNOWLEDGE_BASE_ID=7NGH4NNDFC

# ─── Module Generation Defaults ─────────────────────────────────────────────
# Prefix for generated module directories (terraform-aws-<service>)
MODULE_PREFIX=terraform-aws
# Default provider version constraint
AWS_PROVIDER_VERSION=">= 5.60.0"
# Default terraform version constraint
TERRAFORM_VERSION=">= 1.5"
# Default region for examples
DEFAULT_REGION=ca-central-1

# ─── Knowledge Base Sources ─────────────────────────────────────────────────
# Path to LZA config repo (for extract_lza_config.py)
LZA_CONFIG_DIR=/home/nizar/HomeWspce/aws-accelerator-config-957201034306
# Path to TF modules repo (for extract_tf_registry_v2.py)
TF_MODULES_DIR=/home/nizar/HomeWspce/poc-bnc-terraform-modules
# S3 bucket for KB data (auto-detected if empty)
KB_BUCKET_NAME=
